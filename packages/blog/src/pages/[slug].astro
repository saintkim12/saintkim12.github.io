---
import { getCollection } from 'astro:content';
import BlogLayout from '../layouts/BlogLayout.astro';
import { pathHelpers, metaHelpers } from '../config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: any;
}

const { post } = Astro.props;
const { Content } = await post.render();
const meta = metaHelpers.blogPost(post.data.title, post.data.description);
---

<BlogLayout title={meta.title} description={meta.description}>
  <article class="blog-post">
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <span>{post.data.pubDate.toLocaleDateString('ko-KR')}</span>
        {post.data.author && <span> • {post.data.author}</span>}
      </div>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <Content />
    </div>

    {post.data.relatedDocs && post.data.relatedDocs.length > 0 && (
      <section class="related-docs">
        <h3>관련 문서</h3>
        <ul>
          {post.data.relatedDocs.map((doc) => (
            <li>
              <a href={doc}>{doc}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <nav class="post-nav">
      <a href={pathHelpers.blogList()} class="back-link">← 블로그 목록으로</a>
    </nav>
  </article>

  <style>
    .blog-post {
      max-width: 800px;
      margin: 0 auto;
    }

    .post-header {
      margin-bottom: 2rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid #ddd;
    }

    @media (prefers-color-scheme: dark) {
      .post-header {
        border-bottom-color: #444;
      }
    }

    .post-header h1 {
      margin-top: 0;
      margin-bottom: 0.5rem;
    }

    .post-content {
      line-height: 1.8;
      margin-bottom: 2rem;
    }

    .post-content :global(h2) {
      margin-top: 2rem;
      margin-bottom: 1rem;
    }

    .post-content :global(h3) {
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
    }

    .post-content :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 5px;
      margin: 1rem 0;
    }

    .related-docs {
      background: #f9f9f9;
      padding: 1.5rem;
      border-radius: 5px;
      margin-bottom: 2rem;
    }

    @media (prefers-color-scheme: dark) {
      .related-docs {
        background: #2d2d2d;
      }
    }

    .related-docs h3 {
      margin-top: 0;
    }

    .related-docs ul {
      margin-left: 1.5rem;
    }

    .post-nav {
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid #ddd;
    }

    @media (prefers-color-scheme: dark) {
      .post-nav {
        border-top-color: #444;
      }
    }

    .back-link {
      text-decoration: none;
      color: #007bff;
      font-weight: 500;
    }

    .back-link:hover {
      text-decoration: underline;
    }
  </style>
</BlogLayout>
