---
import { experiences } from '../data/experienceData';
---

<section class="space-y-8 py-12 md:py-20">
  <div class="space-y-2">
    <h2 class="text-3xl font-bold tracking-tighter sm:text-4xl">
      경력
    </h2>
    <p class="text-muted-foreground">
      다양한 기업에서 쌓아온 풀스택 개발 경험
    </p>
  </div>

  <div class="space-y-6">
    {experiences.map((exp, index) => (
      <div key={exp.id}>
        <div class="rounded-lg border border-card bg-card text-card-foreground shadow-sm">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between p-6">
            <div class="space-y-1">
              <h3 class="text-2xl font-semibold leading-none tracking-tight">
                {exp.company}
              </h3>
              <p class="text-base text-muted-foreground">
                {exp.position}
              </p>
              <p class="text-sm text-muted-foreground">
                {exp.period}
              </p>
            </div>
          </div>
          <div class="p-6 pt-0 space-y-4">
            <p class="text-muted-foreground">{exp.description}</p>

            {exp.achievements.length > 0 && (
              <div class="space-y-2">
                <h4 class="font-semibold text-foreground">주요 성과</h4>
                <ul class="space-y-1 text-sm text-muted-foreground">
                  {exp.achievements.map((achievement) => (
                    <li class="flex gap-2">
                      <span class="text-primary">•</span>
                      <span>{achievement}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {exp.technologies.length > 0 && (
              <div class="space-y-2">
                <h4 class="font-semibold text-foreground">기술</h4>
                <div class="flex flex-wrap gap-2">
                  {exp.technologies.map((tech) => (
                    <span key={tech} class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-transparent bg-secondary text-secondary-foreground">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>

        {index < experiences.length - 1 && (
          <div class="flex justify-center py-4">
            <div class="w-1 h-8" style="background-color: var(--muted);"></div>
          </div>
        )}
      </div>
    ))}
  </div>
</section>
